# OneBot 网关地址
# 正向 WebSocket，监听群聊消息
ONEBOT_WS_URL=ws://localhost:6700

# OneBot 鉴权 Token（可选）
# 如果网关不需要鉴权可以不设
ONEBOT_ACCESS_TOKEN=

# LLM API（agent 用）
LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Agent 行为
# BOT_NAME=Rin
# REPLY_CHANCE=0.3
# BOT_QQ=3042160393
# DRY_RUN=true         # true=仅模拟，false=实际发送消息到群聊
# VISION_MODEL=                      # 视觉模型名（空=禁用，如 llama3.2-vision:11b）
# VISION_BASE_URL=http://127.0.0.1:11444/v1  # 视觉 API 地址（默认同 LLM_BASE_URL）

# 自动退出时间（秒）
# 不设则持续运行。设为 3600 则 1 小时后自动退出
# DURATION_SECONDS=
