{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".out",
    "rootDir": ".",
    "declaration": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts"]
}
